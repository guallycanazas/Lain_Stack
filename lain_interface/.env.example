# ==============================================================================
# CanazasTEL Admin Platform — Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ==============================================================================

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="CanazasTEL Admin Platform"
APP_VERSION="1.0.0"
APP_ENV=development
DEBUG=true

# ── Security (CHANGE IN PRODUCTION — use strong random key) ───────────────────
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=canazastel
POSTGRES_PASSWORD=canazastel_dev_pass
POSTGRES_DB=canazastel_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── CORS (comma-separated list of allowed origins) ─────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# ── Lab Integration Connectors (future — leave empty to use mock mode) ─────────
OPEN5GS_API_URL=
KAMAILIO_LOG_PATH=/var/log/kamailio
PYHSS_API_URL=
RAN_CONNECTOR_URL=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
