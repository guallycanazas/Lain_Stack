# CanazasTEL Admin Platform — .gitignore
# ───────────────────────────────────────

# ── Secrets & Environment ─────────────────────────────────────────────
.env
*.env.local
*.env.production

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
ENV/
env/
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Node ──────────────────────────────────────────────────────────────
node_modules/
dist/
.npm
*.tsbuildinfo
.vite/

# ── Docker volumes (local) ────────────────────────────────────────────
docker/volumes/

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ── IDEs ──────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────
*.log
logs/

# ── Alembic ───────────────────────────────────────────────────────────
# Keep alembic/versions but not cached
apps/backend/alembic/versions/__pycache__/
